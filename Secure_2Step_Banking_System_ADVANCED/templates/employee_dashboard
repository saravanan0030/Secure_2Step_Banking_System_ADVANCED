<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Employee Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-5">
    <h2>Welcome, {{ employee.full_name or employee.name }}</h2>
    <a class="btn btn-danger float-end" href="/logout">Logout</a>
    <hr>

    <h4>All Users</h4>
    <table class="table table-bordered mt-3">
        <thead>
            <tr>
                <th>ID</th>
                <th>Account No</th>
                <th>Name</th>
                <th>Email</th>
                <th>Full Name</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Aadhaar</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.account_number }}</td>
                <td>{{ user.name }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.full_name or "-" }}</td>
                <td>{{ user.phone or "-" }}</td>
                <td>{{ user.address or "-" }}</td>
                <td>{{ user.aadhaar or "-" }}</td>
                <td>{{ user.approval_status }}</td>
                <td>
                    <a href="/employee_user/{{ user.id }}" class="btn btn-primary btn-sm">View / Update</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
</body>
</html>